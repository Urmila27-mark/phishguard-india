# 2. Generate an app password for "Mail"
# 3. Paste the 16-character password below (no spaces)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=urmila03jhajhria@gmail.com
SMTP_PASS=ovwf rwfi enug zvmg

# ── Razorpay (for accepting real payments) ──────────────────────────────────
